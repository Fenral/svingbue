{
  "private": true,
  "name": "svingbue-app",
  "version": "1.0.0",
  "description": "Flightglass native packaging scaffold — Capacitor wrapper around the static web app for iOS/TestFlight builds via Codemagic.",
  "scripts": {
    "test": "npm run test:ux",
    "test:academy": "node --test --test-concurrency=1 scripts/academy-backspin-model.test.mjs scripts/academy-lesson-journey.test.mjs scripts/academy-backspin-browser.test.mjs",
    "test:ux": "node --test --test-concurrency=1 scripts/flightglass-ux.test.mjs scripts/academy-backspin-model.test.mjs scripts/academy-lesson-journey.test.mjs scripts/academy-backspin-browser.test.mjs",
    "ux:manifest": "node scripts/flightglass-ux-audit.mjs --manifest-only",
    "ux:baseline": "node scripts/flightglass-ux-audit.mjs --mode baseline --motion both",
    "ux:verify": "node scripts/flightglass-ux-audit.mjs --mode verify --motion both",
    "claude:ready": "npm run brand:verify && npm run test:ux && node scripts/verify-claude-autopilot.mjs",
    "brand:build": "node scripts/build-flightglass-assets.mjs",
    "brand:verify": "node scripts/verify-flightglass-brand.mjs",
    "copy-web": "node scripts/copy-web.mjs",
    "shots": "node scripts/store-screenshots.mjs",
    "sync": "cap sync ios",
    "sync:android": "cap sync android"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.7",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/screen-orientation": "^7.0.0",
    "@revenuecat/purchases-capacitor": "^11.3.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0",
    "fontkit": "^2.0.4",
    "sharp": "^0.34.5"
  }
}
