.vercel

# --- Native packaging (Capacitor) ---
# Node dependencies for the Capacitor scaffold (package.json at repo root).
node_modules/

# The iOS platform project itself is generated fresh on Codemagic's Mac
# (`npx cap add ios`) — it cannot be produced on this Windows dev machine
# (needs Xcode/CocoaPods), so it is never committed. NOTE: this repo
# intentionally does NOT have a committed ios/ directory at all; the
# entries below just make sure CI-generated artifacts inside it (if it
# ever exists locally, e.g. on a future Mac dev machine) don't get committed.
ios/App/Pods/
ios/App/App/public/
ios/DerivedData/
ios/App/build/
ios/App/Podfile.lock

# The Android platform project is generated FRESH in CI on every run
# (.github/workflows/android-debug.yml → `npx cap add android`) — it is
# never committed, mirroring the ios/ approach above. It may exist locally
# only as a temporary artifact of verifying scripts/android-landscape.mjs.
android/

# Assembled web bundle consumed by Capacitor — regenerated by
# `npm run copy-web`, never hand-edited, never committed.
www/

# macOS cruft (harmless on Windows, kept for when this is opened on a Mac)
.DS_Store

# Build outputs
build/
*.ipa
*.app.dSYM
*.dSYM.zip

# Local backups tool sometimes creates
.sa-backups/

# Store-upload screenshots — large, regeneratable outputs of
# `npm run shots` (scripts/store-screenshots.mjs). Kept OUT of git so they
# never bloat CI checkouts; regenerate locally before each store upload.
store-assets/
